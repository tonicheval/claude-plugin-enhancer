{
  "manifest_version": 3,
  "name": "Claude Plugin Enhancer",
  "version": "2.3",
  "description": "Sends claude.ai usage data to the Claude extension status bar (Standardized Enhancer)",
  "permissions": ["alarms", "cookies", "tabs"],
  "host_permissions": ["https://claude.ai/*", "http://localhost/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["https://claude.ai/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}
